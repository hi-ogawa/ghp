  },
  "dependencies": {
    "tsx": "^4.22.3"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.16"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.33.4"
