{
  "name": "ghp",
  "version": "0.1.0",
  "description": "Ergonomic CLI wrapper for GitHub Projects",
  "license": "MIT",
  "bin": {
    "ghp": "./src/bin/cli.js"
  },
  "files": [
    "src",
    "README.md"
  ],
  "type": "module",
  "scripts": {
